# shellcheck shell=bash disable=SC2034,SC2154,SC2086,SC2206
pkgname=signal-desktop-bin
pkgver=8.0.0
pkgrel=1
pkgdesc="Signal Private Messenger (official binary release repack)"
arch=('x86_64')
url="https://signal.org"
license=('AGPL-3.0-only')
depends=(
  'alsa-lib'
  'gcc-libs'
  'glibc'
  'gtk3'
  'libappindicator-gtk3'
  'libdbusmenu-gtk3'
  'libnotify'
  'libpulse'
  'libsecret'
  'libx11'
  'libxss'
  'libxtst'
  'mesa'        # provides libgbm
  'nss'
  'xdg-utils'
)
provides=('signal-desktop')
conflicts=('signal-desktop')
source=("https://updates.signal.org/desktop/apt/pool/s/signal-desktop/signal-desktop_${pkgver}_amd64.deb")
noextract=(signal-desktop_${pkgver}_amd64.deb)
sha512sums=('2ae5a58edd262346e9718ab491d9008b80a257b6edb98049f702e143010caa8a1b2ad0815a42541c4d7cb995a45c99268d6b8d58cda7cb25d079b9a3893e2dfe')

package() {
  bsdtar -xOf "${noextract[0]}" data.tar.xz | tar -xJf - -C "$pkgdir"
}
